{
    "name": "boundwize/structarmed",
    "type": "library",
    "description": "Configurable PHP architecture guards — define your layers and rules, then keep them enforced",
    "keywords": [
        "dev",
        "architecture",
        "analysis",
        "ddd",
        "mvc",
        "layer",
        "enforcement"
    ],
    "homepage": "https://github.com/boundwize/structarmed",
    "license": "MIT",
    "authors": [
        {
            "name": "Abdul Malik Ikhsan",
            "email": "samsonasik@gmail.com",
            "homepage": "http://samsonasik.wordpress.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "composer-runtime-api": "^2.0",
        "fidry/cpu-core-counter": "^1.3",
        "nikic/php-parser": "^5.7"
    },
    "require-dev": {
        "laminas/laminas-coding-standard": "^3.1",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5",
        "rector/rector": "dev-main"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "Boundwize\\StructArmed\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Boundwize\\StructArmed\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "cs-check": "phpcs",
        "cs-fix": "phpcbf",
        "phpstan": "phpstan",
        "rector": "rector process --dry-run",
        "test": "phpunit",
        "structarmed": "php bin/structarmed analyze"
    },
    "bin": [
        "bin/structarmed"
    ]
}
